# ───────────────────────────────────────────
# ArgoDive — Environment Variables
# ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ───────────────────────────────────────────

# ── Database (Neon PostgreSQL) ─────────────
# Main connection URL (uses connection pooler by default)
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/argodive?sslmode=require"

# Direct connection (bypasses pooler — required for Prisma migrations)
DIRECT_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/argodive?sslmode=require"

# ── Cloudinary (Image Upload) ──────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Application URLs ───────────────────────
NEXT_PUBLIC_APP_URL="https://argodive-web.vercel.app"
NEXT_PUBLIC_ADMIN_URL="https://argodive-admin.vercel.app"

# ── Optional: Analytics / Monitoring ───────
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ── Optional: Feature Flags ────────────────
# NEXT_PUBLIC_ENABLE_MOCK_DATA="false"
